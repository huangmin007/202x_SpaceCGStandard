	<!-- 场景配置 -->
	<Scenes StartupSceneId="0">

		<Scene Id="0" Name="流动白色柔光" RFID="0" >
			<Scene.Dictionary>
				<Item Key="浅白色_常亮" Value="#FFDDDDDD" />
				<Item Key="浅白色流水_正向" Value="[[#00DDDDDD,#FFDDDDDD]],[15],1.5,1" />
				<Item Key="浅白色流水_反向" Value="[[#FFDDDDDD,#00DDDDDD]],[15],1.5,-1" />
			</Scene.Dictionary>

			<LedStripObject Address="1" Port="1" Action="FlowLinearBrush" Params="{浅白色流水_正向}" Comment="" />
			<!--
			<LedStripObject Address="1" Port="2" Action="FlowLinearBrush" Params="{浅白色流水_反向}" Comment="" />
			<LedStripObject Address="1" Port="3" Action="FlowLinearBrush" Params="{浅白色流水_正向}" Comment="右3" />
			<LedStripObject Address="1" Port="4" Action="FlowLinearBrush" Params="{浅白色流水_正向}" Comment="" />
			<LedStripObject Address="1" Port="5" Action="FlowLinearBrush" Params="{浅白色流水_反向}" Comment="" />
			<LedStripObject Address="1" Port="6" Action="FlowLinearBrush" Params="{浅白色流水_反向}" Comment="右6" />
-->
		</Scene>

		<Scene Id="1" Name="生物活性材料(浅蓝色)" RFID="0453874754" >
			<Scene.Dictionary>
				<Item Key="浅蓝色_常亮" Value="#FF0066DD" />
				<Item Key="浅蓝色流水_正向" Value="[[#000066DD,#FF0066DD]],[15],1.5,1" />
				<Item Key="浅蓝色流水_反向" Value="[[#FF0066DD,#000066DD]],[15],1.5,-1" />
				<Item Key="浅蓝色流水_正向_右3" Value="170,40,[[#000066DD,#FF0066DD]],[15],1.5,1" />
				<Item Key="浅蓝色流水_正向_右9" Value="21,400,[[#000066DD,#FF0066DD]],[15],1.5,1" />
			</Scene.Dictionary>

			<LedStripObject Address="1" Port="1" Action="FlowLinearBrush" Params="{浅蓝色流水_正向}" Comment="" />
