				<Item Key="浅黄色流水_正向_右9" Value="21,400,[[#11EEEE22,#FFEEEE22]],[15],1.5,1" />
			</Scene.Dictionary>

			<LedStripObject Address="1" Port="3" Action="FlowLinearBrush" Params="{浅黄色流水_正向}" Comment="右3" />
			<LedStripObject Address="1" Port="4" Action="FlowLinearBrush" Params="{浅黄色流水_正向}" Comment="右4" />
			<LedStripObject Address="1" Port="6" Action="FlowLinearBrush" Params="{浅黄色流水_反向}" Comment="右6" />
</Scene>

