<?xml version="1.0" encoding="utf-8" ?>

<Config>

	<Config.Templates>
		<Template Name="DefaultStatusTemplate" Comment="默认状态模板">
		</Template>
		<Template Name="DefaultStatusTemplateId" Comment="默认状态模板">
			<Scene Id="{Id}">
				<RefTemplate Name="DefaultStatusTemplate" />
			</Scene>
		</Template>
	</Config.Templates>

	<WindowSettings ListenerPort="2000" TickInterval="300" RFIDParams="CH H,19200" />

	<DrawingDisplay Rectangle="0,0,400,640" Interval="30" />

	<!-- 灯带设备配置 -->
	<LedDevices>
		<LedRenderBus Type="SERIAL" Params="CH343,460800" Interval="40" Comment="">
			<LedStripObject Address="1" Port="1" ColorFormat="GRB" Count="85" FillCount="15" RepeatCount="17" Comment="右1" />
			<!--
			<LedStripObject Address="1" Port="2" ColorFormat="GRB" Count="165" Comment="右2" />
